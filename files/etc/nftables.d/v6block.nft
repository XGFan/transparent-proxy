chain sip6_547 {
    meta nfproto ipv6 udp dport 547 ether saddr @allow_v6_mac return
    meta nfproto ipv6 udp dport 547 drop
}

chain sip6_fwd {
    meta nfproto ipv6 ether saddr @allow_v6_mac return
    meta nfproto ipv6 reject with icmpv6 admin-prohibited
}

chain input_lan {
    iifname "br-lan" jump sip6_547
}

chain forward_lan {
    iifname "br-lan" jump sip6_fwd
}
